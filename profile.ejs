<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Profile</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #fdfdfd;
            padding: 20px;
            color: #333;
        }
        
        .container {
            max-width: 900px;
            margin: auto;
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            text-align: center;
            margin-bottom: 20px;
        }
        
        .profile-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            border-bottom: 1px solid #eee;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }
        
        .profile-pic-container {
            position: relative;
            width: 150px;
            height: 150px;
            border-radius: 50%;
            overflow: hidden;
            margin-bottom: 15px;
            border: 4px solid #ff416c;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }
        
        .profile-pic-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .upload-form {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .upload-form input[type="file"] {
            font-size: 14px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: linear-gradient(to right, #f8f9fa, #fff);
            padding: 20px;
            border-radius: 8px;
            border-left: 5px solid #0072ff;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
        }
        
        .stat-num {
            font-size: 2em;
            font-weight: bold;
            color: #0072ff;
            margin: 10px 0;
        }
        
        .table-container {
            overflow-x: auto;
            margin-top: 20px;
            text-align: left;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th,
        td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
        }
        
        th {
            background: #f4f4f4;
        }
        
        h1 {
            color: #ff416c;
            margin-bottom: 5px;
        }
        
        .back-btn {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: #0072ff;
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: bold;
            transition: 0.3s;
        }
        
        .back-btn:hover {
            box-shadow: 0 4px 10px rgba(0, 114, 255, 0.4);
        }
        
        .btn-small {
            padding: 6px 12px;
            background: #28a745;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        /* Mobile Optimization */
        
        @media (max-width: 768px) {
            body {
                padding: 15px;
            }
            .container {
                padding: 20px;
            }
            h1 {
                font-size: 1.8em;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="profile-header">
            <div class="profile-pic-container">
                <% if(user.profile_picture) { %>
                    <img src="<%= user.profile_picture %>" alt="Profile Picture">
                    <% } else { %>
                        <img src="https://ui-avatars.com/api/?name=<%= user.name.charAt(0) %>&background=0D8ABC&color=fff&size=150" alt="Default Avatar">
                        <% } %>
            </div>

            <h1>
                <%= user.name %>
            </h1>
            <p style="color: #666; margin-top: 0;">
                <%= user.email %>
            </p>

            <form action="/profile/upload" method="POST" enctype="multipart/form-data" class="upload-form">
                <input type="file" name="profilePic" accept="image/*" required>
                <button type="submit" class="btn-small">Update Picture</button>
            </form>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Total Orders</h3>
                <div class="stat-num">
                    <%= stats.totalOrders %>
                </div>
                <p style="font-size: 0.9em; color:#777;">Orders placed so far</p>
            </div>
            <div class="stat-card">
                <h3 style="color:#28a745;">Items Purchased</h3>
                <div class="stat-num" style="color:#28a745;">
                    <%= stats.itemsBought %>
                </div>
                <p style="font-size: 0.9em; color:#777;">Successfully delivered</p>
            </div>
            <div class="stat-card">
                <h3 style="color:#ffc107;">Pending Orders</h3>
                <div class="stat-num" style="color:#ffc107;">
                    <%= stats.pendingOrders %>
                </div>
                <p style="font-size: 0.9em; color:#777;">Awaiting admin approval</p>
            </div>
        </div>

        <h2 style="text-align: left; border-bottom: 2px solid #eee; padding-bottom: 10px; margin-top: 30px;">Your Wishlist</h2>
        <div class="wishlist-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; padding: 20px 0;">
            <% if (user.wishlist && user.wishlist.length > 0) { %>
                <% user.wishlist.forEach(function(item) { %>
                    <div class="wishlist-card" style="border: 1px solid #ddd; border-radius: 8px; overflow: hidden; text-align: center; padding-bottom: 10px;">
                        <a href="/product/<%= item._id %>"><img src="<%= item.image_url || '/placeholder.png' %>" alt="<%= item.name %>" style="width: 100%; height: 150px; object-fit: cover;"></a>
                        <h4 style="margin: 10px 0 5px;">
                            <%= item.name %>
                        </h4>
                        <p style="color: #4CAF50; font-weight: bold; margin: 0 0 10px;">৳
                            <%= item.price %>
                        </p>
                        <form action="/wishlist/toggle" method="POST" style="margin: 0;">
                            <input type="hidden" name="product_id" value="<%= item._id %>">
                            <button type="submit" style="background-color: transparent; border: 1px solid #ff4d4f; color: #ff4d4f; padding: 5px 12px; border-radius: 4px; cursor: pointer;">Remove</button>
                        </form>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <p style="color: #666; font-style: italic; grid-column: 1 / -1;">Your wishlist is currently empty.</p>
                            <% } %>
        </div>

        <h2 style="text-align: left; border-bottom: 2px solid #eee; padding-bottom: 10px; margin-top: 30px;">Your Order History</h2>

        <div class="table-container">
            <% if (orders && orders.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Products</th>
                            <th>Total Cost</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(function(order) { %>
                            <tr>
                                <td>#
                                    <%= order.id %>
                                </td>
                                <td>
                                    <% if(order.items && order.items.length > 0) { %>
                                        <ul style="margin: 0; padding-left: 15px;">
                                            <% order.items.forEach(item => { %>
                                                <li>
                                                    <%= item.name %>
                                                        <% if(item.size) { %>(
                                                            <%= item.size %>)
                                                                <% } %>
                                                                    (x
                                                                    <%= item.quantity %>)</li>
                                                <% }) %>
                                        </ul>
                                        <% } else { %>
                                            <%= order.product_name %><br><small>Qty: <%= order.quantity || 1 %></small>
                                                <% } %>
                                </td>
                                <td>৳
                                    <%= order.total_amount %>
                                </td>
                                <td>
                                    <span style="font-weight: bold; color: <%= order.status === 'Accepted' ? 'green' : (order.status === 'Declined' ? 'red' : 'orange') %>;">
                                        <%= order.status %>
                                    </span>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% } else { %>
                    <p style="color: #666; font-style: italic; text-align: center; margin: 30px 0;">You haven't placed any orders yet.</p>
                    <% } %>
        </div>

        <a href="/" class="back-btn">Continue Shopping</a>
    </div>
</body>

</html>